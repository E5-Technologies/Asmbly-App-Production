# Podfile
# asmbly iOS App
# Run: pod install
# Then open: asmbly.xcworkspace (NOT .xcodeproj)

platform :ios, '15.0'
use_frameworks!

target 'asmbly' do

  # ── Google Sign-In SDK ────────────────────────────────────────────────────
  pod 'GoogleSignIn', '~> 7.0'

  # ── Supabase Swift SDK (optional — using REST API directly from JS layer) ─
  # Uncomment if you want native Swift Supabase access in addition to JS:
  # pod 'Supabase', '~> 2.0'

end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['SWIFT_VERSION'] = '5.0'
    end
  end
end
